# ─── DATABASE ───────────────────────────────────────────────────────────────
# Production: PostgreSQL (Railway auto-generates these)
DATABASE_URL="postgresql://user:password@localhost:5432/kinetix"
# For connection pooling with Prisma (Railway provides this)
DIRECT_URL="postgresql://user:password@localhost:5432/kinetix"

# Local dev: SQLite (uncomment to use)
# DATABASE_URL="file:./dev.db"

# ─── AUTHENTICATION ─────────────────────────────────────────────────────────
# Google OAuth — get from https://console.cloud.google.com
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ─── AI/VISION ──────────────────────────────────────────────────────────────
# Groq API for receipt scanning (https://console.groq.com)
VISION_API_URL="https://api.groq.com/openai/v1"
VISION_API_KEY="your_groq_api_key"
VISION_MODEL="llama-3.2-11b-vision-preview"

# ─── WEBHOOKS ───────────────────────────────────────────────────────────────
# SMS webhook security token — include in POST header as X-Webhook-Token
SMS_WEBHOOK_TOKEN="generate_a_strong_random_secret"

# ─── FILE STORAGE ───────────────────────────────────────────────────────────
# Local storage (dev); swap for S3/R2 in production
UPLOAD_DIR="./public/uploads/receipts"
UPLOAD_BASE_URL="/uploads/receipts"

# ─── NEXT.JS ────────────────────────────────────────────────────────────────
# Local dev
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Production (update to your Railway domain)
# NEXT_PUBLIC_BASE_URL="https://your-app.railway.app"
