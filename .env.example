# Database — use postgresql:// for production, file:./dev.db for SQLite dev
DATABASE_URL="postgresql://user:password@localhost:5432/kinetix"

# For local SQLite development, use:
# DATABASE_URL="file:./dev.db"

# Vision LLM for receipt scanning (OpenAI-compatible endpoint)
# Groq: https://api.groq.com/openai/v1
# OpenAI: https://api.openai.com/v1
VISION_API_URL="https://api.groq.com/openai/v1"
VISION_API_KEY="your_vision_api_key"
VISION_MODEL="llama-3.2-11b-vision-preview"

# SMS Webhook security token — include in webhook POST header as X-Webhook-Token
SMS_WEBHOOK_TOKEN="generate_a_strong_random_secret"

# File storage — local by default; swap for S3/R2 in production
UPLOAD_DIR="./public/uploads/receipts"
UPLOAD_BASE_URL="/uploads/receipts"

# Next.js
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
